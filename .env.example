# Sanity CMS — required for Studio and blog pages
NEXT_PUBLIC_SANITY_PROJECT_ID=hwyx6cco
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity revalidate webhook secret — required for ISR cache invalidation from Sanity webhooks
# Generate any strong random string (e.g. `openssl rand -hex 32`), then paste the same value into sanity.io/manage → API → Webhooks → Secret
SANITY_REVALIDATE_SECRET=

# Sanity write token — required for migration script (without --dry-run)
# Generate at sanity.io/manage → Project → API → Tokens → Add API token (Editor role)
SANITY_API_WRITE_TOKEN=

# Sanity read token — required for draft previews and authenticated reads from private datasets
# Generate at sanity.io/manage → Project → API → Tokens → Add API token (Viewer role)
SANITY_API_READ_TOKEN=

# Postmark — required for contact form email
# Generate at postmarkapp.com → Server → API Tokens
POSTMARK_API_TOKEN=

# Contact form destination email
# Verify correct address (onpointinstall.com vs onpointinstallations.com) before wiring
CONTACT_FORM_TO_EMAIL=
